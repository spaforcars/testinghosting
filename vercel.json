{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    { "path": "/api/cron/retry-notifications", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/daily-ops-summary", "schedule": "5 * * * *" }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
